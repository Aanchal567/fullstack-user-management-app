<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Create User</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-zinc-900 to-black text-white min-h-screen flex items-center justify-center">

  <!-- CARD -->
  <div class="bg-zinc-900 p-10 rounded-2xl shadow-2xl w-full max-w-md border border-zinc-800">

    <!-- TITLE -->
    <h1 class="text-3xl font-bold mb-6 text-center">Create User</h1>

    <!-- FORM -->
    <form action="/create" method="post" class="space-y-5">

      <!-- NAME -->
      <div>
        <label class="text-sm text-zinc-400">Full Name</label>
        <input 
          type="text" 
          name="name"
          placeholder="Enter name"
          class="w-full mt-1 px-4 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
          required
        />
      </div>

      <!-- EMAIL -->
      <div>
        <label class="text-sm text-zinc-400">Email</label>
        <input 
          type="email" 
          name="email"
          placeholder="Enter email"
          class="w-full mt-1 px-4 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
          required
        />
      </div>

      <!-- IMAGE -->
      <div>
        <label class="text-sm text-zinc-400">Image URL</label>
        <input 
          type="text" 
          name="image"
          placeholder="Paste image link"
          class="w-full mt-1 px-4 py-2 rounded-lg bg-zinc-800 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- BUTTON -->
      <button 
        type="submit"
        class="w-full bg-blue-600 py-2 rounded-lg hover:bg-blue-700 transition shadow-md">
        Create User
      </button>

    </form>

    <!-- LINK -->
    <div class="text-center mt-5">
      <a href="/read" class="text-blue-400 text-sm hover:underline">
        View All Users →
      </a>
    </div>

  </div>

</body>
</html>